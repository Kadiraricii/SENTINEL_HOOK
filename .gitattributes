# ===============================
# Sentinel Hook - .gitattributes
# ===============================

# Set default behaviour, in case users don't have core.autocrlf set.
* text=auto

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout.
*.py text eol=lf
*.js text eol=lf
*.rs text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.json text eol=lf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary

# GitHub Linguist Overrides (Force GitHub to calculate languages accurately)
*.js linguist-language=JavaScript
*.py linguist-language=Python
*.rs linguist-language=Rust
*.md linguist-language=Markdown

# Hide generated files from GitHub's language statistics
package-lock.json linguist-generated=true
Cargo.lock linguist-generated=true
_sentinel_bundle.js linguist-generated=true
